# OpenRouter (recomendado): https://openrouter.ai/keys
# Crie uma chave, deposite saldo e copie aqui.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Modelo via OpenRouter. Default: anthropic/claude-opus-4.7
# Outros: anthropic/claude-sonnet-4.5, anthropic/claude-haiku-4.5, google/gemini-2.5-pro
OPENROUTER_MODEL=anthropic/claude-opus-4.7

# Limite de output em tokens. Opus suporta até 32k.
CLAUDE_MAX_TOKENS=32000

# Tamanhos de chunk (chunks GRANDES por padrão, raramente fragmenta).
# Aumente ainda mais se você processa arquivos enormes.
CHUNK_PDF_PAGES=30
CHUNK_TABULAR_ROWS=600
CHUNK_TEXT_CHARS=100000

# Espera entre chunks. 0 = sem espera (recomendado para OpenRouter).
CLAUDE_RATE_LIMIT_WAIT_SECONDS=0

# Timeout por chamada LLM (segundos). Opus pode demorar com PDF grande.
CLAUDE_TIMEOUT_SECONDS=300

# Self-review pode rodar até este número de registros (acima disso, é skipado).
CLAUDE_SELF_REVIEW_MAX_RECORDS=200

# Senha opcional do app
APP_PASSWORD=
MAX_UPLOAD_MB=30
