# Copie este arquivo para .env e preencha com sua chave real
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Modelo padrão. Troque para claude-opus-4-6 se precisar de mais qualidade no mapeamento
CLAUDE_MODEL=claude-sonnet-4-6

# Limite de tokens de saída. 4096 é suficiente para mapeamentos complexos
CLAUDE_MAX_TOKENS=4096
