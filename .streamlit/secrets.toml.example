# Copie este arquivo para .streamlit/secrets.toml apenas em dev local.
# Em produção (Streamlit Cloud), configure esses valores diretamente no painel.
# NUNCA commite o arquivo secrets.toml real.

ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxx"

CLAUDE_MODEL = "claude-sonnet-4-6"

# Senha simples de acesso. Deixe vazio para desabilitar.
APP_PASSWORD = ""

# Limite de tamanho de upload em MB
MAX_UPLOAD_MB = 30
